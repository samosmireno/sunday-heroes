{
  "name": "sunday-heroes",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:packages": "cd packages && npm run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "dev:combined": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd apps/server && npm run dev",
    "dev:client": "cd apps/client && npm run dev",
    "start": "cd apps/server && npm start",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "concurrently": "^8.2.2",
    "prettier": "^3.5.0",
    "turbo": "^2.4.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "bunchee": "^6.5.0",
    "chart.js": "^4.5.1",
    "node-fetch": "^3.3.2",
    "react-chartjs-2": "^5.3.1"
  },
  "overrides": {
    "fast-xml-parser": ">=5.3.6"
  }
}
